# Optional TLS reverse proxy for Spot.
#
# Spot serves the platform UI, deployed sites, /spot.js, /api/*, authz,
# and 404 pages itself. This proxy only terminates TLS and preserves the
# original host, scheme, and peer IP for Spot.

(tls-internal) {
	tls internal
}

(tls-cloudflare) {
	tls {
		dns cloudflare {env.CF_API_TOKEN}
		resolvers 1.1.1.1
	}
}

{$SPOT_DOMAIN:spot.localhost}, *.{$SPOT_DOMAIN:spot.localhost} {
	import {$SPOT_TLS_MODE:tls-internal}

	reverse_proxy {$SPOT_API_UPSTREAM:127.0.0.1:8080} {
		header_up X-Forwarded-For {client_ip}
		header_up X-Forwarded-Host {hostport}
		header_up X-Forwarded-Proto {scheme}
	}
}
