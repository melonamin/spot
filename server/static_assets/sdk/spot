#!/bin/sh
# spot — deploy static sites to the Spot platform.
# Edit this source copy, then run `just generate` to refresh the served
# sdk/spot copy and the Go-embedded server/static_assets/sdk/spot copy.
#
# Deploys go through the platform's deploy API (the same endpoint the
# apex web deployer uses), so the only configuration is where the
# platform lives. Via environment (or $XDG_CONFIG_HOME/spot/env,
# default ~/.config/spot/env, sourced if present):
#   SPOT_URL   apex URL of the Spot deployment
#              (default http://spot.localhost:8080)
set -eu

# Read SPOT_URL from the config without executing the file: parse it as
# KEY=VALUE and accept only the SPOT_URL key, so a hostile value cannot
# run as shell. An env-provided SPOT_URL takes precedence.
spot_config="${XDG_CONFIG_HOME:-$HOME/.config}/spot/env"
if [ -z "${SPOT_URL:-}" ] && [ -f "$spot_config" ]; then
    while IFS='=' read -r key value; do
        [ "$key" = SPOT_URL ] && SPOT_URL=$value
    done < "$spot_config"
fi

SPOT_URL=${SPOT_URL:-http://spot.localhost:8080}
SPOT_URL=${SPOT_URL%/}
SPOT_SCHEME=${SPOT_URL%%://*}
SPOT_HOSTPORT=${SPOT_URL#*://}
SPOT_DOMAIN=${SPOT_HOSTPORT%%:*}

# Local HTTPS dev may use a private CA; localhost is trusted implicitly.
case $SPOT_DOMAIN in
    localhost|*.localhost) SPOT_CURL_OPTS=-k ;;
    *) SPOT_CURL_OPTS= ;;
esac

banner() {
    if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
        esc=$(printf '\033')
        pink="${esc}[38;5;205m"
        violet="${esc}[38;5;99m"
        mint="${esc}[38;5;48m"
        reset="${esc}[0m"
        printf '%s\n' \
            "${pink}"'   _____             __'"${reset}" \
            "${pink}"'  / ___/____  ____  / /_'"${reset}" \
            "${violet}"'  \__ \/ __ \/ __ \/ __/'"${reset}" \
            "${violet}"' ___/ / /_/ / /_/ / /_'"${reset}" \
            "${mint}"'/____/ .___/\____/\__/'"${reset}" \
            "${mint}"'    /_/'"${reset}" \
            "${violet}"'  Drop a folder, get a spot.'"${reset}" \
            ""
    else
        cat <<'EOF'
   _____             __
  / ___/____  ____  / /_
  \__ \/ __ \/ __ \/ __/
 ___/ / /_/ / /_/ / /_
/____/ .___/\____/\__/
    /_/
  Drop a folder, get a spot.

EOF
    fi
}

usage() {
    banner
    cat <<'EOF'
usage: spot <command>

commands:
  deploy [name] [path]  sync a directory or index.html (default .) to
                        the site <name> (default: current directory name)
  init [options]        write the Spot agent skill for Claude, Codex, or Pi
  update                replace this CLI with the latest from SPOT_URL

init options:
  --agent <list>        comma-separated agents: claude,codex,pi
  --all-agents          install for every supported agent
  --scope <scope>       project or user
  --yes, -y             accept detected defaults without prompting
  --force               overwrite existing skill files
  --dry-run             print target files without writing
EOF
    exit 1
}

deploy() {
    name=${1:-$(basename "$PWD")}
    src=${2:-.}
    if [ "$#" -eq 1 ] && [ -f "$1" ] && [ "$(basename "$1")" = "index.html" ]; then
        name=$(basename "$PWD")
        src=$1
    fi
    case $name in
        *[!a-z0-9-]*|'')
            echo "error: site name '$name' must match [a-z0-9-]+" >&2
            exit 1
            ;;
    esac
    if [ -f "$src" ]; then
        file=$(basename "$src")
        dir=$(dirname "$src")
        if [ "$file" != "index.html" ]; then
            echo "error: single-file deploys must be named index.html" >&2
            exit 1
        fi
    else
        dir=$src
        if [ ! -e "$dir/index.html" ]; then
            echo "error: $dir/index.html not found — a site needs at least an index.html" >&2
            exit 1
        fi
    fi
    echo "deploying $src -> $name.$SPOT_DOMAIN"

    # One -F part per file, the filename carrying the site-relative path
    # — the shape /api/deploy expects. The server syncs: files absent
    # from the upload are removed from the live site. Dot directories
    # (.git and friends) stay home; the server drops them anyway.
    #
    # Quote the path and filename= values so curl does not treat ';' ','
    # or '@' in a filename as -F metacharacters.
    set -- -F "site=$name"
    if [ -f "$src" ]; then
        set -- "$@" -F "files=@\"$file\";filename=\"index.html\""
    else
        while IFS= read -r f; do
            [ -n "$f" ] || continue
            f=${f#./}
            set -- "$@" -F "files=@\"$f\";filename=\"$f\""
        done <<EOF
$(cd "$dir" && find . -name '.?*' -prune -o -type f -print)
EOF
    fi

    # Capture curl's exit without tripping set -e, so a network/HTTP
    # failure reaches the friendly message below instead of aborting.
    if ! out=$(cd "$dir" && curl -sS $SPOT_CURL_OPTS -w '\n%{http_code}' \
        "$@" "$SPOT_URL/api/deploy"); then
        echo "error: could not reach $SPOT_URL/api/deploy" >&2
        exit 1
    fi
    status=$(printf '%s' "$out" | tail -n 1)
    body=$(printf '%s' "$out" | sed '$d')
    if [ "$status" != "200" ]; then
        echo "error: deploy failed (HTTP $status): $body" >&2
        exit 1
    fi
    echo "live: $SPOT_SCHEME://$name.$SPOT_HOSTPORT/"
}

current_executable() {
    case $0 in
        */*) path=$0 ;;
        *)
            path=$(command -v "$0" 2>/dev/null || true)
            ;;
    esac
    [ -n "$path" ] || { echo "error: could not resolve spot executable" >&2; exit 1; }
    case $path in
        /*) ;;
        *) path=$(pwd -P)/$path ;;
    esac

    dir=$(dirname "$path")
    base=$(basename "$path")
    if ! dir=$(cd "$dir" && pwd -P); then
        echo "error: could not resolve spot executable directory" >&2
        exit 1
    fi
    printf '%s/%s\n' "$dir" "$base"
}

update_cli() {
    while [ $# -gt 0 ]; do
        case $1 in
            --help|-h)
                cat <<EOF
usage: spot update

Downloads $SPOT_URL/spot and replaces this executable if it changed.
EOF
                exit 0
                ;;
            *)
                echo "error: unknown update option '$1'" >&2
                exit 1
                ;;
        esac
    done

    target=$(current_executable)
    target_dir=${target%/*}
    target_base=${target##*/}
    tmp=$(mktemp "${TMPDIR:-/tmp}/spot-update.XXXXXX")
    staged="$target_dir/.$target_base.update.$$"

    cleanup_update() {
        rm -f "$tmp" "$staged"
    }
    trap cleanup_update EXIT INT TERM

    echo "checking $SPOT_URL/spot"
    if ! curl -fsSL $SPOT_CURL_OPTS "$SPOT_URL/spot" -o "$tmp"; then
        echo "error: could not download $SPOT_URL/spot" >&2
        exit 1
    fi
    if ! sh -n "$tmp"; then
        echo "error: downloaded CLI is not a valid shell script" >&2
        exit 1
    fi
    if cmp -s "$tmp" "$target"; then
        echo "spot is already up to date: $target"
        exit 0
    fi

    if ! cp "$tmp" "$staged"; then
        echo "error: could not stage update in $target_dir" >&2
        exit 1
    fi
    chmod 755 "$staged"
    if ! mv "$staged" "$target"; then
        echo "error: could not replace $target" >&2
        exit 1
    fi
    echo "updated spot -> $target"
}

agent_label() {
    case $1 in
        claude) echo "Claude Code" ;;
        codex)  echo "Codex" ;;
        pi)     echo "Pi" ;;
        *)      echo "$1" ;;
    esac
}

validate_agent() {
    case $1 in
        claude|codex|pi) ;;
        *)
            echo "error: unsupported agent '$1' (want claude, codex, or pi)" >&2
            exit 1
            ;;
    esac
}

validate_scope() {
    case $1 in
        project|user) ;;
        *)
            echo "error: unsupported scope '$1' (want project or user)" >&2
            exit 1
            ;;
    esac
}

project_skill_path() {
    case $1 in
        claude) echo ".claude/skills/spot/SKILL.md" ;;
        codex)  echo ".codex/skills/spot/SKILL.md" ;;
        pi)     echo ".pi/skills/spot/SKILL.md" ;;
    esac
}

user_skill_path() {
    case $1 in
        claude) echo "${CLAUDE_HOME:-$HOME/.claude}/skills/spot/SKILL.md" ;;
        codex)  echo "${CODEX_HOME:-$HOME/.codex}/skills/spot/SKILL.md" ;;
        pi)     echo "${PI_HOME:-$HOME/.pi}/skills/spot/SKILL.md" ;;
    esac
}

skill_path() {
    case $2 in
        project) project_skill_path "$1" ;;
        user)    user_skill_path "$1" ;;
    esac
}

agent_detect() {
    case $1 in
        claude)
            [ -d .claude ] && { echo "project .claude/ exists"; return 0; }
            [ -d "${CLAUDE_HOME:-$HOME/.claude}" ] && { echo "user ~/.claude/ exists"; return 0; }
            command -v claude >/dev/null 2>&1 && { echo "claude command found"; return 0; }
            ;;
        codex)
            [ -d .codex ] && { echo "project .codex/ exists"; return 0; }
            [ -d "${CODEX_HOME:-$HOME/.codex}" ] && { echo "user ~/.codex/ exists"; return 0; }
            command -v codex >/dev/null 2>&1 && { echo "codex command found"; return 0; }
            ;;
        pi)
            [ -d .pi ] && { echo "project .pi/ exists"; return 0; }
            [ -d "${PI_HOME:-$HOME/.pi}" ] && { echo "user ~/.pi/ exists"; return 0; }
            command -v pi >/dev/null 2>&1 && { echo "pi command found"; return 0; }
            ;;
    esac
    echo "not detected"
    return 1
}

is_project_dir() {
    [ -d .git ] && return 0
    [ -d .claude ] && return 0
    [ -d .codex ] && return 0
    [ -d .pi ] && return 0
    [ -f package.json ] && return 0
    [ -f go.mod ] && return 0
    [ -f pyproject.toml ] && return 0
    [ -f index.html ] && return 0
    if command -v git >/dev/null 2>&1 && git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        return 0
    fi
    return 1
}

agent_in_list() {
    needle=$1
    for item in $selected_agents; do
        [ "$item" = "$needle" ] && return 0
    done
    return 1
}

add_agent() {
    validate_agent "$1"
    if ! agent_in_list "$1"; then
        selected_agents="${selected_agents}${selected_agents:+ }$1"
    fi
}

add_agent_list() {
    for agent in $(printf '%s' "$1" | tr ',' ' '); do
        [ -n "$agent" ] && add_agent "$agent"
    done
}

default_agents() {
    selected_agents=
    for agent in claude codex pi; do
        if agent_detect "$agent" >/dev/null 2>&1; then
            add_agent "$agent"
        fi
    done
    [ -n "$selected_agents" ] || add_agent claude
}

print_agent_picker() {
    echo "Which agents should get the Spot skill?"
    for agent in claude codex pi; do
        mark=" "
        agent_in_list "$agent" && mark="x"
        if reason=$(agent_detect "$agent"); then
            status="detected: $reason"
        else
            status="$reason"
        fi
        printf '  [%s] %s  %s\n' "$mark" "$(agent_label "$agent")" "$status"
    done
}

prompt_scope() {
    default_scope=project
    is_project_dir || default_scope=user

    echo "Where should Spot instructions be installed?"
    if [ "$default_scope" = project ]; then
        echo "  1) Project skill (recommended): ./<agent>/skills/spot/SKILL.md"
        echo "  2) User skill: ~/.<agent>/skills/spot/SKILL.md"
    else
        echo "  1) User skill (recommended): ~/.<agent>/skills/spot/SKILL.md"
        echo "  2) Project skill: ./<agent>/skills/spot/SKILL.md"
    fi
    printf 'Scope [%s]: ' "$default_scope"
    IFS= read -r answer || answer=
    case ${answer:-$default_scope} in
        1)
            if [ "$default_scope" = project ]; then init_scope=project; else init_scope=user; fi
            ;;
        2)
            if [ "$default_scope" = project ]; then init_scope=user; else init_scope=project; fi
            ;;
        p|project) init_scope=project ;;
        u|user)    init_scope=user ;;
        *)
            echo "error: unsupported scope '$answer' (want project or user)" >&2
            exit 1
            ;;
    esac
}

prompt_agents() {
    default_agents
    print_agent_picker
    printf 'Agents [%s]: ' "$(printf '%s' "$selected_agents" | tr ' ' ',')"
    IFS= read -r answer || answer=
    if [ -n "$answer" ]; then
        selected_agents=
        add_agent_list "$answer"
    fi
}

confirm_write() {
    echo "Install Spot skill for:"
    echo "  scope: $init_scope"
    echo "  agents: $(printf '%s' "$selected_agents" | tr ' ' ',')"
    for agent in $selected_agents; do
        echo "  - $(skill_path "$agent" "$init_scope")"
    done
    printf 'Write files? [Y/n]: '
    IFS= read -r answer || answer=
    case ${answer:-y} in
        y|Y|yes|YES) ;;
        *) echo "cancelled"; exit 0 ;;
    esac
}

render_skill() {
    cat <<EOF
---
name: spot
description: Build and deploy sites on Spot, the internal hosting platform. Use when creating or updating a Spot site, or when a site needs identity, database, realtime, file uploads, text AI, or AI image generation.
---

# Spot

Spot hosts static sites for everyone on the internal network. A site is a
folder with an index.html, or a single index.html file. Deploy with
\`spot deploy <name>\` from the site directory or
\`spot deploy <name> index.html\`; it is then live at
$SPOT_SCHEME://<name>.$SPOT_HOSTPORT/.

There is no build step and no framework. Plain HTML/CSS/JS works best.

## Gallery preview

The public gallery shows a thumbnail for each site. Ship a screenshot of
the finished page named \`_screenshot.jpg\` (\`.png\` or \`.webp\` also
work) at the site root and the gallery uses it; without one the site
falls back to a generated placeholder. After building a site, capture it
at a desktop size (about 1280x800) and include the image in the deploy.

## Source downloads

Every site exposes its deployed source as a ZIP at \`/api/download\` on
the site origin, for example
\`$SPOT_SCHEME://<name>.$SPOT_HOSTPORT/api/download\`. When you build a
site, assume other authorized visitors can download the exact deployed
HTML/CSS/JS and assets from there.

If the site should be viewable but not downloadable, ship
\`{ "download": false }\` in \`_access.json\`. This does not restrict
normal page access unless an \`allow\` list is also present.

## Backend SDK

Load the SDK with \`<script src="/spot.js"></script>\`. Everything is
same-origin and zero-config — no API keys, no auth code.

### Identity

\`\`\`js
const me = await spot.me();
// { email, name, peer_name, peer_ip, groups, ai_allowed } — from the mesh.
// ai_allowed reports whether this visitor may call spot.ai on this site, so a
// page can show or hide AI features without provoking a 403.
\`\`\`

### Database (schemaless document collections, private to this site)

\`\`\`js
const posts = spot.db.collection('posts');
const doc = await posts.create({ title: 'Hello' }); // { id, owner, data, created_at, updated_at }
const docs = await posts.list({ limit: 100 });      // newest first
const next = await posts.list({ limit: 100, after: docs.at(-1)?.id });
const mine = await posts.list({ mine: true });      // only docs this visitor created
await posts.get(doc.id);
await posts.update(doc.id, { title: 'Bye' });       // replaces data
await posts.updateMine(doc.id, { title: 'Mine' });  // only if this visitor owns it
await posts.delete(doc.id);
await posts.deleteMine(doc.id);

// Filter, sort, count, and batch reads. where ops: eq ne gt gte lt lte in.
const open = await posts.list({ where: { status: 'open' }, sort: 'priority', order: 'desc' });
const hot = await posts.list({ where: { score: { gte: 10 } } });
const n = await posts.count({ where: { status: 'open' } });
const some = await posts.getMany([id1, id2]);       // missing ids omitted
for await (const doc of posts.iterate({ pageSize: 100 })) { /* every doc, paged */ }

// Atomic counter — no read-modify-write, safe under concurrency:
await posts.increment(doc.id, 'views');             // +1
await posts.increment(doc.id, 'score', 5);
\`\`\`

Collection names must match [a-z0-9_-]{1,64}. Documents are JSON objects
up to 1 MB. Each document records an \`owner\` — the mesh identity that
created it — so multiple visitors can keep private data in one shared
site; \`list({ mine: true })\` returns only the caller's documents. Writes
are not restricted to the owner by default, so use \`updateMine\`,
\`deleteMine\`, \`incrementMine\`, or \`{ mine: true }\` on mutations when
only the creator should be able to change a document.

\`where\` and \`sort\` address top-level JSON fields. \`update\` replaces a
document; \`increment\` adds to a numeric field in one atomic step, so it is
the right tool for vote/view/like counters. The \`after\` cursor applies
only to the default newest-first order, not to a custom \`sort\`.

Collections are private to this site, except collections named
\`shared-*\`: those are global and readable/writable by every Spot site.
Use the prefix deliberately — for cross-site libraries, leaderboards,
and the like.

### Realtime

Subscribe to a collection to receive every visitor's changes live —
this is how to build collaborative and multiplayer sites:

\`\`\`js
const unsubscribe = posts.subscribe({
  onCreate: (doc) => { /* doc = { id, owner, data, created_at, updated_at } */ },
  onUpdate: (doc) => {},
  onDelete: (id) => {},
}, { replay: true }); // replay emits the current documents as onCreate first,
                      // then live changes, with no missed or duplicated events
\`\`\`

Prefer rendering from subscription events over polling or re-fetching
after writes. With \`{ replay: true }\` you can render purely from
\`onCreate\`/\`onUpdate\`/\`onDelete\` without a separate initial \`list()\`.

For transient multiplayer/control-panel traffic, use ephemeral realtime
rooms. Room messages are not stored; they go to the other subscribers in
the room. Presence updates when visitors join, leave, or call
\`setPresence\`:

\`\`\`js
const room = spot.realtime.room('control');
room.on('cursor', ({ from, data }) => renderCursor(from.email, data));
room.onPresence((users) => renderOnline(users));
room.onStatus((status) => renderConnection(status)); // connecting/open/reconnecting/closed
room.setPresence({ role: 'operator' });
room.send('cursor', { x: 12, y: 8 });
\`\`\`

Rooms are private to this site except \`shared-*\` rooms, which are
global across Spot sites. Use rooms for cursors, player movement,
operator presence, live controls, and other state that should not be
persisted to the database.

### AI: text and image generation

Call AI from the browser — the OpenAI-compatible gateway key lives on the
server. By default this is limited to the site owner or platform admins;
authorized visitors can use it only when the deployment sets
SPOT_AI_ACCESS=visitors or the site opts in with \`"ai":"visitors"\` in
\`_access.json\`.

\`\`\`js
const res = await spot.ai.chat([{ role: 'user', content: 'Summarize my tasks' }]);
// res = { text, model, stop_reason, usage }
// Optional second-level fields in the request: system, max_tokens.
// model is accepted only when the deployment allowlists it.

// Stream tokens as they arrive (same options as chat, plus onToken/signal):
const final = await spot.ai.stream(
  [{ role: 'user', content: 'Write a haiku' }],
  { onToken: (delta, text) => render(text) },
);
// final = { text, model, stop_reason, usage }

const art = await spot.ai.image('A tiny cyberpunk greenhouse at night');
// art = { provider, model, images: [{ b64, mime_type, data_url }] }
const img = new Image();
img.src = art.images[0].data_url;
document.body.append(img);

// Supports any /v1/images/generations model exposed by the gateway.
// Common models include OpenAI gpt-image-2 and Nano Banana 2 through
// the deployment's LiteLLM alias, such as gemini-3.1-flash-image-preview.
\`\`\`

### File uploads

\`\`\`js
const stored = await spot.files.upload(fileInput.files[0]);
// stored = { id, name, size, content_type, url } — content is immutable
// per upload (25 MB max). If this site is restricted, downloads are too.

const files = await spot.files.list();   // [{ id, name, size, url }, ...]
await spot.files.delete(stored);         // or spot.files.delete(id, name)
\`\`\`

### Site management (Spot root only)

\`\`\`js
const mine = await spot.sites.mine();
const publicSites = await spot.sites.public();
await spot.sites.delete('old-demo');
\`\`\`

These platform APIs work from the Spot root, not from site subdomains.

### Errors and rate limits

Per-visitor: database 25 req/s, realtime room sends 30 req/s, uploads
2 req/s, AI 1 request per 2s (burst 10). A 429 means slow down — do
not hammer APIs in loops.

Every call rejects with a \`spot.SpotError\` carrying \`status\`, a coarse
\`code\` (\`rate_limited\`, \`forbidden\`, \`unauthorized\`, \`not_found\`,
\`conflict\`, \`bad_request\`, \`server\`, \`network\`, \`stream\`), and
\`retryAfter\` (seconds) on a 429. The SDK retries rate-limited and transient
failures automatically with backoff, so a brief 429 usually resolves without
code; tune or disable it with \`spot.configure({ retry })\` (true, false, or a
max-retry count) or a per-call \`{ retry }\` option.

When rendering stored documents, set text via textContent / DOM APIs —
never interpolate document data into innerHTML.

### Access control (optional)

Sites are open to everyone by default. To restrict a site, deploy an
\`_access.json\` at its root:

\`\`\`json
{ "allow": ["alice@corp.com", "team-payments"] }
\`\`\`

Entries with an @ match the visitor's email; all others match a mesh
group name. The file applies to the whole site including its database
API. It is an allowlist, not a secret — permitted visitors can read it.
Add \`"ai":"visitors"\` only when those permitted visitors should be
allowed to spend the deployment's server-side AI key.
Add \`"download":false\` to opt out of source ZIP downloads while keeping
normal page access unchanged.

The first deploy of a site claims it. Later deploys, including changes
to \`_access.json\`, require the same owner identity or a platform admin.
EOF
}

write_skill() {
    target=$1

    if [ "$init_dry_run" = 1 ]; then
        echo "would write $target"
        return 0
    fi

    if [ -e "$target" ] && [ "$init_force" != 1 ]; then
        echo "skipped $target (exists; use --force)"
        return 0
    fi

    mkdir -p "${target%/*}"
    render_skill > "$target"
    echo "wrote $target"
}

init() {
    init_scope=
    selected_agents=
    explicit_agents=0
    all_agents=0
    init_yes=0
    init_force=0
    init_dry_run=0

    while [ $# -gt 0 ]; do
        case $1 in
            --agent)
                [ $# -gt 1 ] || { echo "error: --agent needs a value" >&2; exit 1; }
                explicit_agents=1
                add_agent_list "$2"
                shift 2
                ;;
            --agent=*)
                explicit_agents=1
                add_agent_list "${1#--agent=}"
                shift
                ;;
            --all-agents)
                all_agents=1
                shift
                ;;
            --scope)
                [ $# -gt 1 ] || { echo "error: --scope needs a value" >&2; exit 1; }
                validate_scope "$2"
                init_scope=$2
                shift 2
                ;;
            --scope=*)
                init_scope=${1#--scope=}
                validate_scope "$init_scope"
                shift
                ;;
            --yes|-y)
                init_yes=1
                shift
                ;;
            --force)
                init_force=1
                shift
                ;;
            --dry-run)
                init_dry_run=1
                shift
                ;;
            --help|-h)
                usage
                ;;
            *)
                echo "error: unknown init option '$1'" >&2
                exit 1
                ;;
        esac
    done

    if [ "$all_agents" = 1 ] && [ "$explicit_agents" = 1 ]; then
        echo "error: use either --agent or --all-agents, not both" >&2
        exit 1
    fi

    if [ -z "$init_scope" ]; then
        if [ "$init_yes" = 1 ] || ! [ -t 0 ]; then
            if is_project_dir; then init_scope=project; else init_scope=user; fi
        else
            prompt_scope
        fi
    fi

    if [ "$all_agents" = 1 ]; then
        selected_agents="claude codex pi"
    elif [ "$explicit_agents" != 1 ]; then
        if [ "$init_yes" = 1 ] || ! [ -t 0 ]; then
            default_agents
        else
            prompt_agents
        fi
    fi

    [ -n "$selected_agents" ] || { echo "error: no agents selected" >&2; exit 1; }

    if [ "$init_yes" != 1 ] && [ "$init_dry_run" != 1 ] && [ -t 0 ]; then
        confirm_write
    fi

    for agent in $selected_agents; do
        write_skill "$(skill_path "$agent" "$init_scope")"
    done
}

cmd=${1:-help}
[ $# -gt 0 ] && shift
case $cmd in
    deploy) deploy "$@" ;;
    init)   init "$@" ;;
    update) update_cli "$@" ;;
    *)      usage ;;
esac
