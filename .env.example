# Copy to .env and adjust. Shared deployments need exactly one mesh
# identity provider: NetBird or Tailscale. Single-user homelab deployments
# can instead set SPOT_AUTH_MODE=single-user.

# RustFS root credentials. These defaults are only accepted for
# .localhost development and single-user homelab deployments;
# shared/mesh deployments must replace them or spot-api refuses to start.
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin

# Storage mode. Empty/s3 stores site files and uploads in S3-compatible
# blob storage while metadata lives in SQLite. Set local for the smallest
# single-binary install with file storage under SPOT_DATA_DIR.
SPOT_STORAGE_MODE=
SPOT_DATA_DIR=./data
SPOT_SQLITE_PATH=
SPOT_S3_ENDPOINT=rustfs:9000
SPOT_UPLOADS_BUCKET=spot-uploads
SPOT_SITES_BUCKET=spot-sites
# Local site root in local storage mode. Defaults to $SPOT_DATA_DIR/sites.
SPOT_SITES_DIR=
# S3 credentials. Under docker compose these are populated from
# RUSTFS_ACCESS_KEY/RUSTFS_SECRET_KEY; set them directly only for the
# non-compose single-binary S3 path.
#SPOT_S3_ACCESS_KEY=
#SPOT_S3_SECRET_KEY=

# Port (or address) spot-api listens on; also settable via the --listen
# flag. Defaults to 8080.
PORT=8080

# Domain sites are served under. Production: spot.<your-domain>; the
# wildcard DNS record should point at this host's mesh IP.
SPOT_DOMAIN=spot.localhost

# Auth mode. Leave empty/auto for the normal mesh-backed model. Set
# SPOT_AUTH_MODE=single-user for a trusted homelab where everyone who can
# reach Spot acts as the same owner. Keep SPOT_SINGLE_USER_EMAIL stable;
# changing it changes the deploy owner key for future authorization.
SPOT_AUTH_MODE=
SPOT_SINGLE_USER_EMAIL=owner@spot.local
SPOT_SINGLE_USER_NAME=Spot Owner
SPOT_SINGLE_USER_GROUPS=

# Homelab overlay domain (docker-compose.homelab.yml). Publish this apex
# and its wildcard to the VM's LAN/VPN IP.
SPOT_HOMELAB_DOMAIN=spot.home.arpa

# NetBird management API, used to resolve visitor identity from peer IPs.
# Configure either this block or the Tailscale block below, not both.
NETBIRD_API_URL=
NETBIRD_API_TOKEN=

# Tailscale API, used to resolve visitor identity from peer IPs. Use either
# a static API token or an OAuth client pair. TAILSCALE_TAILNET defaults to
# "-" (the token's tailnet) when left empty.
TAILSCALE_API_URL=
TAILSCALE_API_TOKEN=
TAILSCALE_TAILNET=
TAILSCALE_OAUTH_CLIENT_ID=
TAILSCALE_OAUTH_CLIENT_SECRET=

# Deploys require identity. For local-only development without a mesh API,
# set an explicit dev identity; leave empty in shared/prod deployments.
SPOT_DEV_IDENTITY_EMAIL=
SPOT_DEV_IDENTITY_NAME=Spot Dev
SPOT_DEV_IDENTITY_GROUPS=

# Comma-separated emails/groups that may deploy any existing site.
SPOT_ADMIN_EMAILS=
SPOT_ADMIN_GROUPS=

# Front proxies whose X-Forwarded-* headers spot-api trusts. Direct
# deployments only need loopback. Add your reverse proxy's IP/CIDR if you
# put one in front of spot-api.
SPOT_TRUSTED_PROXIES=127.0.0.1/32,::1/128

# Mesh overlay (docker-compose.mesh.yml) only.
SPOT_MESH_DOMAIN=spot.test

# Optional TLS overlay (docker-compose.tls.yml). Use tls-cloudflare for
# public wildcard certificates via DNS-01; CF_API_TOKEN needs
# Zone:Zone:Read and Zone:DNS:Edit.
SPOT_TLS_MODE=tls-internal
CF_API_TOKEN=

# Server-side key for the zero-config spot.ai proxy. This is an
# OpenAI-compatible API key; for LiteLLM, use the LiteLLM virtual key.
# Leave empty to run without AI (/api/ai/chat and /api/ai/image return 503).
OPENAI_API_KEY=

# Optional OpenAI-compatible upstream for spot.ai. For LiteLLM, set this
# to the proxy origin, for example http://litellm:4000.
OPENAI_BASE_URL=

# Default chat model for spot.ai requests that name none. Empty means gpt-5;
# set it when the upstream gateway serves a different model list or aliases.
SPOT_AI_MODEL=

# Comma-separated models callers may request explicitly. The deployment
# default is always allowed; every other per-request model must be named.
SPOT_AI_ALLOWED_MODELS=

# Default AI image-generation model for spot.ai.image requests that name none.
# Empty means gpt-image-2. With LiteLLM this can be any /v1/images/generations
# alias, including your Nano Banana 2 route.
SPOT_AI_IMAGE_MODEL=

# Comma-separated image models callers may request explicitly. The configured
# default plus gemini-3.1-flash-image and gpt-image-2 are allowed by default.
SPOT_AI_ALLOWED_IMAGE_MODELS=

# owners: site owner/platform admins only. visitors: every authorized
# visitor may use the server-side AI key. A site can also opt visitors in
# with {"allow":[...], "ai":"visitors"} in _access.json.
SPOT_AI_ACCESS=owners
