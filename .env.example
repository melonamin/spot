# Copy to .env and adjust. Shared deployments need exactly one mesh
# identity provider: NetBird or Tailscale. Single-user homelab deployments
# can instead set SPOT_AUTH_MODE=single-user.

# RustFS root credentials (also used by rclone). These defaults are only
# accepted for .localhost development; shared/mesh deployments must
# replace them or spot-api refuses to start.
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin

# Local-only default; replace for shared/mesh deployments.
POSTGRES_PASSWORD=spot

# Domain sites are served under. Production: spot.<your-domain>; the
# wildcard DNS record should point at this host's mesh IP.
SPOT_DOMAIN=spot.localhost

# Auth mode. Leave empty/auto for the normal mesh-backed model. Set
# SPOT_AUTH_MODE=single-user for a trusted homelab where everyone who can
# reach Spot acts as the same owner. Keep SPOT_SINGLE_USER_EMAIL stable;
# changing it changes the deploy owner key for future authorization.
SPOT_AUTH_MODE=
SPOT_SINGLE_USER_EMAIL=owner@spot.local
SPOT_SINGLE_USER_NAME=Spot Owner
SPOT_SINGLE_USER_GROUPS=

# Homelab overlay domain (docker-compose.homelab.yml). Publish this apex
# and its wildcard to the VM's LAN/VPN IP.
SPOT_HOMELAB_DOMAIN=spot.home.arpa

# NetBird management API, used to resolve visitor identity from peer IPs.
# Configure either this block or the Tailscale block below, not both.
NETBIRD_API_URL=
NETBIRD_API_TOKEN=

# Tailscale API, used to resolve visitor identity from peer IPs. Use either
# a static API token or an OAuth client pair. TAILSCALE_TAILNET defaults to
# "-" (the token's tailnet) when left empty.
TAILSCALE_API_URL=
TAILSCALE_API_TOKEN=
TAILSCALE_TAILNET=
TAILSCALE_OAUTH_CLIENT_ID=
TAILSCALE_OAUTH_CLIENT_SECRET=

# Deploys require identity. For local-only development without a mesh API,
# set an explicit dev identity; leave empty in shared/prod deployments.
SPOT_DEV_IDENTITY_EMAIL=
SPOT_DEV_IDENTITY_NAME=Spot Dev
SPOT_DEV_IDENTITY_GROUPS=

# Comma-separated emails/groups that may deploy any existing site.
SPOT_ADMIN_EMAILS=
SPOT_ADMIN_GROUPS=

# Front proxies whose X-Forwarded-* headers spot-api trusts. The local
# compose network is pinned to 172.28.0.0/24; the mesh overlay narrows
# this to the single Docker gateway address (172.28.0.1/32).
SPOT_TRUSTED_PROXIES=127.0.0.1/32,::1/128,172.28.0.0/24

# Mesh overlay (docker-compose.mesh.yml) only. SPOT_SITE_LABEL is the
# number of labels in the domain (spot.test -> 2, spot.t1a.dev -> 3).
# SPOT_TLS_MODE=tls-cloudflare needs CF_API_TOKEN (Zone:DNS:Edit) for the
# publicly trusted DNS-01 wildcard cert; see caddy/Caddyfile.
SPOT_MESH_DOMAIN=spot.test
SPOT_SITE_LABEL=2
SPOT_TLS_MODE=tls-internal
CF_API_TOKEN=

# Server-side Claude API key for the zero-config spot.ai proxy.
# Leave empty to run without it (/api/ai/chat returns 503).
ANTHROPIC_API_KEY=

# Optional Anthropic-compatible upstream for spot.ai (an LLM gateway or
# proxy). Empty means the Claude API itself.
ANTHROPIC_BASE_URL=

# Default model for spot.ai requests that name none. Empty means the
# platform default (claude-opus-4-8); set it when the upstream gateway
# serves a different model list.
SPOT_AI_MODEL=

# Comma-separated models callers may request explicitly. The deployment
# default is always allowed; every other per-request model must be named.
SPOT_AI_ALLOWED_MODELS=

# owners: site owner/platform admins only. visitors: every authorized
# visitor may use the server-side AI key. A site can also opt visitors in
# with {"allow":[...], "ai":"visitors"} in _access.json.
SPOT_AI_ACCESS=owners
